# Backend API origin for production deployment.
# Example: VITE_API_BASE_URL=https://your-backend-service.cloudtype.app
VITE_API_BASE_URL=

# Optional. Use only when the websocket endpoint uses a different origin.
# Example: VITE_WS_BASE_URL=wss://your-backend-service.cloudtype.app
VITE_WS_BASE_URL=
